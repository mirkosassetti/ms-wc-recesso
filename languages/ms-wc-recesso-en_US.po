#. Plugin Name of the plugin
msgid "MS Recesso 54-bis per WooCommerce"
msgstr "MS Withdrawal 54-bis for WooCommerce"

#. Description of the plugin
msgid "Implementa la funzione di recesso obbligatoria ex art. 54-bis del Codice del Consumo (D.Lgs. 209/2025, Direttiva UE 2023/2673) per e-commerce B2C."
msgstr "Implements the mandatory withdrawal function under art. 54-bis of the Italian Consumer Code (Legislative Decree 209/2025, EU Directive 2023/2673) for B2C e-commerce."

msgid "Recesso dal contratto"
msgstr "Withdrawal from the contract"

msgid "Recesso 54-bis"
msgstr "Withdrawal 54-bis"

msgid "Recesso"
msgstr "Withdrawal"

msgid "Richieste di recesso"
msgstr "Withdrawal requests"

msgid "Richieste"
msgstr "Requests"

msgid "Impostazioni recesso"
msgstr "Withdrawal settings"

msgid "Impostazioni"
msgstr "Settings"

msgid "Cerca"
msgstr "Search"

msgid "Richiesta non trovata."
msgstr "Request not found."

msgid "Permesso negato."
msgstr "Permission denied."

msgid "Nessuna richiesta di recesso per questo ordine."
msgstr "No withdrawal requests for this order."

msgid "(da verificare)"
msgstr "(to review)"

msgid "Escluso dal recesso (art. 59)"
msgstr "Excluded from withdrawal (art. 59)"

msgid "Se attivo, questo prodotto non sarà selezionabile nel flusso di recesso."
msgstr "If enabled, this product cannot be selected in the withdrawal flow."

msgid "Motivo esclusione"
msgstr "Exclusion reason"

msgid "Mostrato al cliente accanto all’articolo escluso (facoltativo)."
msgstr "Shown to the customer next to the excluded item (optional)."

msgid "Richiesta"
msgstr "Request"

msgid "Cliente"
msgstr "Customer"

msgid "Stato"
msgstr "Status"

msgid "Verifica"
msgstr "Review"

msgid "Ordine"
msgstr "Order"

msgid "Creata"
msgstr "Created"

msgid "Tutte"
msgstr "All"

msgid "Da verificare"
msgstr "To review"

msgid "Nessuna richiesta di recesso."
msgstr "No withdrawal requests."

msgid "Articolo escluso dal diritto di recesso ai sensi dell’art. 59 del Codice del Consumo."
msgstr "Item excluded from the right of withdrawal under art. 59 of the Consumer Code."

#, php-format
msgid "Recesso ex art. 54-bis trasmesso (rif. %1$s) in data %2$s."
msgstr "Withdrawal under art. 54-bis transmitted (ref. %1$s) on %2$s."

msgid "Recesso — notifica amministratore"
msgstr "Withdrawal — admin notification"

msgid "Inviata all’amministratore quando un recesso viene trasmesso."
msgstr "Sent to the administrator when a withdrawal is transmitted."

msgid "[{site_title}] Nuova richiesta di recesso — ordine {order_reference}"
msgstr "[{site_title}] New withdrawal request — order {order_reference}"

msgid "Nuova richiesta di recesso"
msgstr "New withdrawal request"

msgid "Recesso — verifica email (ospite)"
msgstr "Withdrawal — email verification (guest)"

msgid "Inviata all’ospite per confermare l’email e accedere alla dichiarazione di recesso."
msgstr "Sent to the guest to confirm the email and access the withdrawal declaration."

msgid "Conferma la tua richiesta di recesso"
msgstr "Confirm your withdrawal request"

msgid "Richiesta di recesso"
msgstr "Withdrawal request"

msgid "Recesso — ricevuta al consumatore"
msgstr "Withdrawal — receipt to the consumer"

msgid "Ricevuta di avvenuto recesso inviata al consumatore, con contenuto della dichiarazione e data/ora."
msgstr "Acknowledgement of withdrawal sent to the consumer, with the declaration content and date/time."

msgid "Ricevuta di recesso — ordine {order_reference}"
msgstr "Withdrawal receipt — order {order_reference}"

msgid "Recesso trasmesso"
msgstr "Withdrawal transmitted"

msgid "Ordine non trovato o non associato al tuo account."
msgstr "Order not found or not associated with your account."

msgid "Questo ordine non è idoneo al recesso."
msgstr "This order is not eligible for withdrawal."

msgid "Sessione scaduta, riprova."
msgstr "Session expired, please try again."

msgid "Inserisci il tuo nome."
msgstr "Please enter your name."

msgid "Inserisci un indirizzo email valido per ricevere la conferma."
msgstr "Please enter a valid email address to receive the confirmation."

msgid "Seleziona almeno un articolo idoneo al recesso."
msgstr "Please select at least one item eligible for withdrawal."

msgid "Richiesta di recesso non trovata."
msgstr "Withdrawal request not found."

msgid "Il link di verifica non è valido o è scaduto."
msgstr "The verification link is invalid or has expired."

msgid "Troppi tentativi. Riprova tra qualche minuto."
msgstr "Too many attempts. Please try again in a few minutes."

msgid "Inserisci il numero dell’ordine."
msgstr "Please enter the order number."

msgid "Inserisci un indirizzo email valido."
msgstr "Please enter a valid email address."

msgid "Non siamo riusciti ad abbinare automaticamente l’ordine indicato: la richiesta sarà comunque registrata e verificata manualmente."
msgstr "We could not automatically match the order provided: the request will still be recorded and verified manually."

msgid "Questa richiesta non può essere confermata."
msgstr "This request cannot be confirmed."

msgid "Torna indietro"
msgstr "Go back"

msgid "Recedere dal contratto qui"
msgstr "Withdraw from the contract here"

msgid "In attesa di verifica"
msgstr "Pending verification"

msgid "Bozza"
msgstr "Draft"

msgid "In lavorazione"
msgstr "In progress"

msgid "Approvato"
msgstr "Approved"

msgid "Respinto (fuori ambito)"
msgstr "Rejected (out of scope)"

msgid "Completato"
msgstr "Completed"

msgid "Prodotto di esempio"
msgstr "Sample product"

msgid "Esempio di motivo del reso"
msgstr "Sample return reason"

msgid "MS Recesso 54-bis richiede WooCommerce attivo per funzionare."
msgstr "MS Withdrawal 54-bis requires WooCommerce to be active."

msgid "Dettaglio richiesta di recesso"
msgstr "Withdrawal request detail"

msgid "Torna all’elenco"
msgstr "Back to the list"

msgid "Stato aggiornato."
msgstr "Status updated."

msgid "Dati"
msgstr "Data"

msgid "Riferimento"
msgstr "Reference"

msgid "Email"
msgstr "Email"

msgid "apri ordine"
msgstr "open order"

msgid "Verifica manuale"
msgstr "Manual review"

msgid "Sì"
msgstr "Yes"

msgid "No"
msgstr "No"

msgid "Trasmesso il"
msgstr "Transmitted on"

msgid "Motivo"
msgstr "Reason"

msgid "Articoli"
msgstr "Items"

msgid "Ricevuta inviata"
msgstr "Receipt sent"

msgid "Gestione"
msgstr "Management"

msgid "Nuovo stato:"
msgstr "New status:"

msgid "Aggiorna stato"
msgstr "Update status"

msgid "Nessuna transizione disponibile da questo stato."
msgstr "No transition available from this status."

msgid "Cronologia"
msgstr "History"

msgid "Impostazioni recesso 54-bis"
msgstr "Withdrawal 54-bis settings"

msgid "Pulsante e posizionamenti"
msgstr "Button and placements"

msgid "Testo del pulsante"
msgstr "Button text"

msgid "Testo del pulsante di conferma"
msgstr "Confirmation button text"

msgid "Posizionamenti"
msgstr "Placements"

msgid "Pulsante nel footer del sito"
msgstr "Button in the site footer"

msgid "Link nella lista ordini (Il mio account)"
msgstr "Link in the orders list (My account)"

msgid "Link nel dettaglio ordine"
msgstr "Link in the order details"

msgid "Finestra di recesso"
msgstr "Withdrawal window"

msgid "Giorni di recesso"
msgstr "Withdrawal days"

msgid "default 14"
msgstr "default 14"

msgid "Giorni stimati di consegna dopo il completamento"
msgstr "Estimated delivery days after completion"

msgid "aggiunto alla data di completamento (default 2)"
msgstr "added to the completion date (default 2)"

msgid "Giorni stimati di consegna dalla creazione"
msgstr "Estimated delivery days from creation"

msgid "usato se l’ordine non è completato (default 4)"
msgstr "used if the order is not completed (default 4)"

msgid "Ospiti e notifiche"
msgstr "Guests and notifications"

msgid "Validità link di verifica (ore)"
msgstr "Verification link validity (hours)"

msgid "default 48"
msgstr "default 48"

msgid "Email per le notifiche admin"
msgstr "Email for admin notifications"

msgid "vuoto = email amministratore del sito"
msgstr "empty = site administrator email"

msgid "Esclusioni art. 59"
msgstr "Art. 59 exclusions"

msgid "Motivo predefinito di esclusione"
msgstr "Default exclusion reason"

msgid "Mostrato accanto agli articoli esclusi quando il prodotto non ha un motivo specifico."
msgstr "Shown next to excluded items when the product has no specific reason."

msgid "Categorie escluse"
msgstr "Excluded categories"

msgid "I prodotti nelle categorie selezionate (e nelle relative sottocategorie) non saranno selezionabili nel recesso."
msgstr "Products in the selected categories (and their subcategories) cannot be selected for withdrawal."

msgid "Nessuna categoria prodotto disponibile."
msgstr "No product categories available."

msgid "Disinstallazione"
msgstr "Uninstall"

msgid "Conserva le richieste alla disinstallazione (consigliato: sono documenti probatori)"
msgstr "Keep requests on uninstall (recommended: they are evidentiary records)"

#, php-format
msgid "I testi delle email (oggetto e intestazione) si modificano in <a href=\"%s\">WooCommerce &rarr; Impostazioni &rarr; Email</a>."
msgstr "Email texts (subject and heading) are edited in <a href=\"%s\">WooCommerce &rarr; Settings &rarr; Emails</a>."

msgid "La tua dichiarazione di recesso è stata trasmessa correttamente."
msgstr "Your withdrawal declaration has been transmitted successfully."

#, php-format
msgid "Data e ora della trasmissione: %s"
msgstr "Date and time of transmission: %s"

msgid "Riferimento richiesta"
msgstr "Request reference"

#, php-format
msgid "A breve riceverai un’email di conferma all’indirizzo %s con il contenuto della dichiarazione e la data/ora della trasmissione."
msgstr "You will shortly receive a confirmation email at %s with the declaration content and the date/time of transmission."

msgid "È stata trasmessa una nuova dichiarazione di recesso."
msgstr "A new withdrawal declaration has been transmitted."

msgid "Ordine:"
msgstr "Order:"

msgid "Cliente:"
msgstr "Customer:"

msgid "Data e ora:"
msgstr "Date and time:"

msgid "Riferimento:"
msgstr "Reference:"

msgid "Attenzione:"
msgstr "Warning:"

msgid "la richiesta è da verificare manualmente (ordine non abbinato o fuori termine stimato)."
msgstr "the request must be reviewed manually (unmatched order or beyond the estimated deadline)."

msgid "Apri la richiesta di recesso"
msgstr "Open the withdrawal request"

msgid "Apri l’ordine"
msgstr "Open the order"

msgid "Abbiamo ricevuto una richiesta di recesso relativa al seguente ordine:"
msgstr "We have received a withdrawal request for the following order:"

msgid "Per proseguire e trasmettere la dichiarazione di recesso, apri il link seguente (valido 48 ore):"
msgstr "To proceed and transmit the withdrawal declaration, open the following link (valid for 48 hours):"

msgid "Prosegui con il recesso"
msgstr "Continue with the withdrawal"

msgid "Se non hai richiesto tu il recesso, ignora questa email."
msgstr "If you did not request the withdrawal, please ignore this email."

msgid "ATTENZIONE: richiesta da verificare manualmente (ordine non abbinato o fuori termine stimato)."
msgstr "WARNING: request to be reviewed manually (unmatched order or beyond the estimated deadline)."

msgid "Apri la richiesta:"
msgstr "Open the request:"

msgid "Apri l’ordine:"
msgstr "Open the order:"

#, php-format
msgid "Gentile %s,"
msgstr "Dear %s,"

#, php-format
msgid "confermiamo di aver ricevuto la tua dichiarazione di recesso relativa all’ordine %s."
msgstr "we confirm receipt of your withdrawal declaration for order %s."

msgid "Data e ora della trasmissione:"
msgstr "Date and time of transmission:"

msgid "Contenuto della dichiarazione"
msgstr "Declaration content"

msgid "Nome e cognome:"
msgstr "Full name:"

msgid "Email:"
msgstr "Email:"

msgid "Articoli:"
msgstr "Items:"

msgid "Motivo del reso:"
msgstr "Return reason:"

msgid "Riferimento richiesta:"
msgstr "Request reference:"

msgid "Dichiarazione di recesso"
msgstr "Withdrawal declaration"

msgid "In base ai nostri dati il periodo di recesso potrebbe essere scaduto. Puoi comunque inviare la dichiarazione: sarà registrata con data e ora e verificata dal nostro personale."
msgstr "According to our records the withdrawal period may have expired. You can still submit the declaration: it will be recorded with date and time and reviewed by our staff."

#, php-format
msgid "n. %1$s del %2$s"
msgstr "no. %1$s of %2$s"

msgid "Nome e cognome"
msgstr "Full name"

msgid "Email per la conferma"
msgstr "Email for the confirmation"

msgid "Riceverai qui la conferma con data e ora della trasmissione."
msgstr "You will receive the confirmation here with the date and time of transmission."

msgid "Articoli dai quali recedere"
msgstr "Items to withdraw from"

msgid "Motivo del reso (facoltativo)"
msgstr "Return reason (optional)"

msgid "Prosegui al riepilogo"
msgstr "Continue to the summary"

msgid "Riepilogo della dichiarazione"
msgstr "Declaration summary"

msgid "Controlla i dati. Il recesso sarà trasmesso solo dopo aver premuto il pulsante di conferma."
msgstr "Check the details. The withdrawal will be transmitted only after you press the confirmation button."

msgid "Motivo del reso"
msgstr "Return reason"

msgid "Non specificato"
msgstr "Not specified"

msgid "Nota: la richiesta risulta oltre il termine stimato e sarà verificata manualmente. La data e l’ora di trasmissione faranno comunque fede."
msgstr "Note: the request is beyond the estimated deadline and will be reviewed manually. The date and time of transmission will still be authoritative."

msgid "Modifica"
msgstr "Edit"

msgid "Conferma recesso"
msgstr "Confirm withdrawal"

msgid "Non siamo riusciti ad abbinare automaticamente l’ordine indicato. Puoi comunque trasmettere la dichiarazione: sarà registrata con data e ora e verificata manualmente."
msgstr "We could not automatically match the order provided. You can still transmit the declaration: it will be recorded with date and time and verified manually."

msgid "Hai acquistato senza account? Inserisci il numero dell’ordine e l’email usata in fase di acquisto: ti invieremo un link per proseguire con la dichiarazione di recesso."
msgstr "Purchased without an account? Enter the order number and the email used at purchase: we will send you a link to proceed with the withdrawal declaration."

msgid "Numero dell’ordine"
msgstr "Order number"

msgid "Email usata per l’ordine"
msgstr "Email used for the order"

msgid "Prosegui"
msgstr "Continue"

msgid "Controlla la tua email"
msgstr "Check your email"

#, php-format
msgid "Ti abbiamo inviato un’email a %s con un link per proseguire con la dichiarazione di recesso. Il link è valido 48 ore."
msgstr "We have sent an email to %s with a link to proceed with the withdrawal declaration. The link is valid for 48 hours."

msgid "Se non ricevi l’email entro pochi minuti, controlla la cartella spam."
msgstr "If you do not receive the email within a few minutes, check your spam folder."

msgid "Seleziona l’ordine dal quale desideri recedere. Potrai poi scegliere gli articoli e confermare."
msgstr "Select the order you want to withdraw from. You can then choose the items and confirm."

msgid "Non risultano ordini idonei associati al tuo account."
msgstr "There are no eligible orders associated with your account."

#, php-format
msgid "Ordine n. %s"
msgstr "Order no. %s"

msgid "Recedere da questo ordine"
msgstr "Withdraw from this order"
